{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "g++",
            "args": [
                "-c",
                "g++ -std=c++17 $(pkg-config --cflags gtkmm-4.0) ${workspaceFolder}/*.cc -o ${workspaceFolder}/my_app $(pkg-config --libs gtkmm-4.0)"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
